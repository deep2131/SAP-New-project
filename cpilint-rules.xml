<?xml version="1.0" encoding="UTF-8"?>
<cpilint>

    <rules>

        <!-- Ensure all iFlows have a meaningful name -->
        <rule id="integration-flow-name">
            <severity>error</severity>
        </rule>

        <!-- Ensure all iFlows have descriptions -->
        <rule id="integration-flow-description">
            <severity>warning</severity>
        </rule>

        <!-- Check for hardcoded endpoints -->
        <rule id="hardcoded-endpoint">
            <severity>error</severity>
        </rule>

        <!-- Check for hardcoded credentials or sensitive values -->
        <rule id="hardcoded-credentials">
            <severity>error</severity>
        </rule>

        <!-- Validate externalized parameters -->
        <rule id="externalized-parameters">
            <severity>error</severity>
        </rule>

        <!-- Check naming convention -->
        <rule id="naming-convention">
            <severity>warning</severity>
        </rule>

        <!-- Check exception subprocess availability -->
        <rule id="exception-subprocess">
            <severity>warning</severity>
        </rule>

    </rules>

</cpilint>
