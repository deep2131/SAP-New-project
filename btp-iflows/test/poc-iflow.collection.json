{
  "info": {
    "name": "poc-iflow - QA Test Suite",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "" },
    { "key": "tokenUrl", "value": "" },
    { "key": "clientId", "value": "" },
    { "key": "clientSecret", "value": "" },
    { "key": "accessToken", "value": "" }
  ],
  "item": [
    {
      "name": "TC01 - Call poc-iflow endpoint",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var tokenUrl = pm.variables.get('tokenUrl');",
              "if (tokenUrl && tokenUrl.indexOf('/oauth/token') === -1) {",
              "  tokenUrl = tokenUrl.replace(/\\/$/, '') + '/oauth/token';",
              "}",
              "pm.sendRequest({",
              "  url: tokenUrl,",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
              "  body: { mode: 'urlencoded', urlencoded: [",
              "    { key: 'grant_type', value: 'client_credentials' },",
              "    { key: 'client_id', value: pm.variables.get('clientId') },",
              "    { key: 'client_secret', value: pm.variables.get('clientSecret') }",
              "  ]}",
              "}, function (err, res) {",
              "  if (!err && res.code === 200) {",
              "    pm.variables.set('accessToken', res.json().access_token);",
              "  }",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response time under 10s', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
        },
        "url": {
          "raw": "{{baseUrl}}/http/poc-iflow",
          "host": ["{{baseUrl}}"],
          "path": ["http", "poc-iflow"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"test\": \"data\"}"
        }
      }
    }
  ]
}
