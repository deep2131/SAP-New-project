{
  "info": {
    "name": "new-iflow - QA Test Suite",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "" },
    { "key": "tokenUrl", "value": "" },
    { "key": "clientId", "value": "" },
    { "key": "clientSecret", "value": "" },
    { "key": "accessToken", "value": "" },
    { "key": "csrfToken", "value": "" }
  ],
  "item": [
    {
      "name": "TC01 - POST to new-iflow (CSRF-aware)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ===== STEP 1: Get OAuth token =====",
              "var tokenUrl = pm.variables.get('tokenUrl');",
              "if (tokenUrl && tokenUrl.indexOf('/oauth/token') === -1) {",
              "  tokenUrl = tokenUrl.replace(/\\/$/, '') + '/oauth/token';",
              "}",
              "",
              "pm.sendRequest({",
              "  url: tokenUrl,",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/x-www-form-urlencoded' },",
              "  body: {",
              "    mode: 'urlencoded',",
              "    urlencoded: [",
              "      { key: 'grant_type', value: 'client_credentials' },",
              "      { key: 'client_id', value: pm.variables.get('clientId') },",
              "      { key: 'client_secret', value: pm.variables.get('clientSecret') }",
              "    ]",
              "  }",
              "}, function (err, res) {",
              "  if (!err && res.code === 200) {",
              "    var token = res.json().access_token;",
              "    pm.variables.set('accessToken', token);",
              "    console.log('OAuth token acquired');",
              "",
              "    // ===== STEP 2: Fetch CSRF token via GET =====",
              "    pm.sendRequest({",
              "      url: pm.variables.get('baseUrl') + '/http/new-iflow',",
              "      method: 'GET',",
              "      header: {",
              "        'Authorization': 'Bearer ' + token,",
              "        'x-csrf-token': 'fetch'",
              "      }",
              "    }, function (csrfErr, csrfRes) {",
              "      if (!csrfErr) {",
              "        var csrf = csrfRes.headers.get('x-csrf-token');",
              "        if (csrf) {",
              "          pm.variables.set('csrfToken', csrf);",
              "          console.log('CSRF token fetched: ' + csrf);",
              "        } else {",
              "          console.log('No CSRF token in response headers');",
              "        }",
              "      } else {",
              "        console.log('CSRF fetch error:', csrfErr);",
              "      }",
              "    });",
              "  } else {",
              "    console.log('OAuth token failed:', err || res.code);",
              "  }",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response time under 10s', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(10000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "x-csrf-token", "value": "{{csrfToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/http/new-iflow",
          "host": ["{{baseUrl}}"],
          "path": ["http", "new-iflow"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"test\": \"data\"}"
        }
      }
    }
  ]
}
